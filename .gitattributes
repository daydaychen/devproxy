# Git 属性配置

# 自动检测文本文件
* text=auto

# Go 文件使用 LF 换行符
*.go text eol=lf

# Makefile 使用 LF 换行符
Makefile text eol=lf

# 配置文件使用 LF 换行符
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# 脚本文件使用 LF 换行符
*.sh text eol=lf

# 文档文件使用 LF 换行符
*.md text eol=lf
*.txt text eol=lf

# 二进制文件不进行文本转换
*.exe binary
*.dll binary
*.so binary
*.a binary
*.o binary
